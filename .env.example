# ===========================================
# CRASHBOT CONFIGURATION
# ===========================================

# API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=your-claude-api-key-here
BING_SEARCH_API_KEY=your-bing-search-key-here
GOOGLE_SEARCH_API_KEY=your-google-api-key-here

# Database Configuration
DATABASE_URL=postgresql+asyncpg://crashbot:crashbot_password@localhost:5435/crashbot_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration (for caching and queue)
REDIS_URL=redis://localhost:6381/0
REDIS_CACHE_TTL=3600

# Storage Configuration
STORAGE_TYPE=local  # Options: local, s3, gcs, azure
DUMP_STORAGE_PATH=./storage/dumps
MAX_DUMP_SIZE_MB=500
DUMP_RETENTION_DAYS=30

# AWS S3 (if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=crashbot-dumps

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
API_KEY_SALT=change-this-salt-for-api-keys
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:8002

# LLM Configuration
LLM_PROVIDER=openai  # Options: openai, anthropic, huggingface, local
LLM_MODEL=gpt-4  # or gpt-4-turbo, claude-3-opus, etc.
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# Vector Database Configuration (Phase 1.5)
VECTOR_DB_TYPE=chroma  # Options: chroma, pinecone, weaviate
CHROMA_PATH=./storage/chroma_db
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
EMBEDDING_MODEL=text-embedding-ada-002

# Symbol Server Configuration
MICROSOFT_SYMBOL_SERVER=https://msdl.microsoft.com/download/symbols
SYMBOL_CACHE_PATH=./storage/symbols
SYMBOL_TIMEOUT_SECONDS=30

# WinDbg/Debugger Configuration
WINDBG_PATH=C:\Program Files (x86)\Windows Kits\10\Debuggers\x64\cdb.exe
DEBUGGER_TIMEOUT_SECONDS=120
MAX_STACK_DEPTH=50

# Worker/Queue Configuration (Phase 4)
CELERY_BROKER_URL=redis://localhost:6381/1
CELERY_RESULT_BACKEND=redis://localhost:6381/2
WORKER_CONCURRENCY=4

# Monitoring & Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
SENTRY_DSN=your-sentry-dsn-here
ENABLE_METRICS=true
PROMETHEUS_PORT=9090

# Email Notifications (Phase 5)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@crashbot.dev

# Slack Integration (Phase 5)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_NOTIFICATIONS_ENABLED=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Feature Flags (Phase 5)
ENABLE_BATCH_ANALYSIS=false
ENABLE_CHAT_FOLLOWUP=false
ENABLE_CODE_INTEGRATION=false
ENABLE_ML_CLASSIFICATION=false

# Environment
ENVIRONMENT=development  # Options: development, staging, production
DEBUG=true
